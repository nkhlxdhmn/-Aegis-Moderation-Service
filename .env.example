# Aegis Moderation optional environment template.
# The platform runs with no configuration after `docker compose up`.
# Copy to `.env` only when you want to tune runtime behavior.

# Runtime label used in logs and diagnostics.
ENVIRONMENT=local

# Optional GPU selection. Leave empty or set to `all`/a CUDA device index in Docker.
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all

# Optional model/runtime tuning. Models are downloaded lazily by their libraries and are not committed.
MODEL_WARMUP=false
VLM_DEVICE=cuda:0
YOLO_CUSTOM_MODEL_PATH=
YOLO_OPEN_VOCAB=false
YOLO_CONFIDENCE=0.30
YOLO_IOU=0.45
TEXT_CLASSIFIER_MODEL_DIR=
EMBEDDING_CACHE_DIR=./data
CALIBRATION_FILE=./data/calibration.json

# Image ingestion limits used by the standalone API.
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_PIXELS=40000000
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=12
