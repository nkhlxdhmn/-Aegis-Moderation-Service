{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Aegis Moderation",
  "uid": "aegis-moderation-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(aegis_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency (s)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aegis_analysis_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_requests_total{status=\"error\"}[5m])) / sum(rate(aegis_requests_total[5m]))",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Analysis Latency (P50 / P95 / P99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(aegis_analysis_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aegis_analysis_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(aegis_analysis_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Moderation Decisions Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(moderation_requests_total[5m])) by (decision)",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Category Flags Over Time",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_category_flagged_total[5m])) by (category)",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Model Inference Latency",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aegis_inference_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p95"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Security Events",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_security_events_total[5m])) by (event_type)",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Model Errors",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(moderation_model_errors_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Content Type Distribution",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(aegis_content_type_total[5m])) by (content_type)",
          "legendFormat": "{{content_type}}"
        }
      ]
    }
  ]
}
